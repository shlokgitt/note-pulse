{
  "rules": {
    "notes": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["status", "roomCode", "subject", "createdAt", "userId"],
      "$noteId": {
        ".write": "root.child('notes').child($noteId).child('userId').val() == auth.uid || root.child('admins').child(auth.uid).exists()"
      }
    },
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".read": "$uid == auth.uid || root.child('admins').child(auth.uid).exists()",
        ".write": "$uid == auth.uid"
      }
    },
    "admins": {
      ".read": "auth != null && root.child('admins').child(auth.uid).exists()",
      ".write": "root.child('admins').child(auth.uid).exists()"
    },
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomId": {
        ".write": "root.child('rooms').child($roomId).child('ownerId').val() == auth.uid"
      }
    }
  }
}